# Obrigatórios para rodar o fluxo principal
KB_URL=https://raw.githubusercontent.com/igortce/python-agent-challenge/refs/heads/main/python_agent_knowledge_base.md

# Configuração do LLM (obrigatória no fluxo principal)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=
LLM_BASE_URL=

# Configuração de validação e recuperação de contexto
MAX_MESSAGE_CHARS=4000
MIN_SECTION_SCORE=1
MAX_CONTEXT_SECTIONS=3
KB_TIMEOUT_SECONDS=10
LLM_TIMEOUT_SECONDS=30

# Configuração de logging
LOG_LEVEL=INFO

# Opcionais / Diferenciais
# Opcional (só se implementar memória por sessão)
MEMORY_STORE=
SESSION_TTL_SECONDS=1800
SESSION_MAX_TURNS=5

# Configuração da API
HOST=0.0.0.0
PORT=8000
